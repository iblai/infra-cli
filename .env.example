# iblai infra launch — environment variables
# Copy to .env and fill in real values. Never commit .env to git.

# AWS Credentials
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-1

# Infrastructure
AMI_ID=ami-0123456789abcdef0
HOSTED_ZONE_ID=Z0123456789ABCDEFGHIJ
VPN_IP=203.0.113.1
INSTANCE_TYPE=t3.2xlarge
VOLUME_SIZE=200
ENVIRONMENT=staging

# SSH
SSH_PUBLIC_KEY="ssh-rsa AAAA... user@host"
SSH_KEY_PATH=~/.ssh/id_rsa

# Domain
DOMAIN=platform.example.com

# GitHub
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Platform Admin.
# NOTE: `ibl_admin` is reserved for system use — pick a different name.
ADMIN_USERNAME=platform_admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-8-chars

# Optional
OPENAI_API_KEY=
ENABLE_AI=true

# WAF (optional, single-server only) — attaches a WAFv2 Web ACL to the ALB
# with admin-only allow rules for Swagger UI, Studio, /admin/, /data. Plus
# AWS managed rule groups and a .git/.env path-traversal block. Bare IPs are
# auto-suffixed with /32; CIDR is accepted as-is.
# ENABLE_WAF=false
# WAF_ALLOWED_IPS=203.0.113.7,198.51.100.0/24
