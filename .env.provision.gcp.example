# iblai infra provision-env — GCP single-server
# Copy to .env, fill in values, then run:
#   iblai infra provision-env -f .env
# Never commit a populated .env to git — .gitignore blocks .env.* by default.

# --- Provider (required for GCP) ---
PROVIDER=gcp

# --- GCP project + auth ---
GCP_PROJECT_ID=my-gcp-project      # the project ID (not the display name)
# Auth is one of:
#   (a) Application Default Credentials — run `gcloud auth application-default login`
#       and leave GCP_CREDENTIALS_FILE unset (good for local use), OR
#   (b) a service-account key JSON (good for CI):
# GCP_CREDENTIALS_FILE=/path/to/service-account-key.json

# --- Region / zone (optional, defaults shown) ---
GCP_REGION=us-central1
GCP_ZONE=us-central1-a             # default: <GCP_REGION>-a

# --- Project identity (required) ---
PROJECT_NAME=mydeploy              # alphanumeric + - _, <= 32 chars, lowercased
ENVIRONMENT=staging                # dev | staging | prod  (default: staging)

# --- Domain (required) ---
DOMAIN=platform.example.com        # base domain — 19 IBL subdomains derived from this

# --- SSH access (required) ---
VPN_IP=auto                        # 'auto' uses your current public IP; or e.g. 203.0.113.7
SSH_KEY_METHOD=generate            # generate | existing_file  (GCP has no aws_keypair)
# If SSH_KEY_METHOD=existing_file, set ONE of:
# SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
# SSH_PUBLIC_KEY="ssh-ed25519 AAAA... user@host"
# SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519   # optional, for the follow-up `iblai infra setup` step

# --- Compute (optional, defaults shown) ---
# NOTE: e2-standard-8 has 32 GB RAM. If you enable AI features in the setup
# step, a 64 GB machine (e.g. e2-standard-16 or n2-highmem-8) is recommended.
MACHINE_TYPE=e2-standard-8
VOLUME_SIZE=100                    # min 100 GB (boot disk)
DISK_TYPE=pd-balanced             # pd-balanced | pd-ssd | pd-standard
# IMAGE=projects/my-project/global/images/my-prebuilt-image   # optional custom image

# --- Network (optional) ---
SUBNET_CIDR=10.0.0.0/16            # primary range of the regional subnet

# --- Certificates (optional, default: auto) ---
# auto    -> Google-managed cert if a Cloud DNS zone matches DOMAIN, else HTTP-only
# managed -> require a Cloud DNS zone (set DNS_ZONE_NAME or CREATE_DNS_ZONE)
# upload  -> use uploaded PEMs (set CERT_*_PATH below)
# none    -> HTTP-only
CERT_METHOD=auto

# Cloud DNS zone (for the managed-cert path):
# DNS_ZONE_NAME=my-zone            # the zone's RESOURCE name (not the dnsName)
# CREATE_DNS_ZONE=false            # true: create the zone + print nameservers to delegate

# Required only when CERT_METHOD=upload (PEM must include the full chain):
# CERT_BODY_PATH=/path/to/fullchain.pem
# CERT_KEY_PATH=/path/to/private.key

# --- Cloud DNS conflict handling (optional) ---
# When a managed cert is used against an EXISTING zone that already has A/CNAME
# records for any of the IBL subdomains, they must be removed before our A
# records replace them. true (default) deletes them; false fails fast.
AUTO_DELETE_CONFLICTING_DNS=true

# NOTE: GCP provisions no object storage. The platform continues to use AWS S3;
# supply AWS credentials at the setup step (`iblai infra setup`), not here.
